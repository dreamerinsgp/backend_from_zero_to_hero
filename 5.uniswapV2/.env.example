# Copy to .env and fill in (never commit .env)

# Sepolia (or other network) HTTPS RPC
RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Hex private key of the caller (with or without 0x prefix)
PRIVATE_KEY=

# scripts/deploy.js — optional; defaults to deployer
# FEE_TO_SETTER=0x0000000000000000000000000000000000000000

# scripts/deploy-test-tokens.js — optional supplies in wei
# SUPPLY_A_WEI=
# SUPPLY_B_WEI=

# scripts/create-pair.js — required to create a pool
# FACTORY_ADDRESS=0x...
# TOKEN_A=0x...
# TOKEN_B=0x...

# scripts/check-pair-liquidity.js — read-only (no PRIVATE_KEY)
# PAIR_ADDRESS=0x...

# scripts/add-liquidity.js — PAIR_ADDRESS + PRIVATE_KEY; amounts either:
#   AMOUNT0_WEI=... AMOUNT1_WEI=...  (for token0 / token1 from the pair)
# or TOKEN_A/B + AMOUNT_A_WEI + AMOUNT_B_WEI (same as deploy:tokens labels)
# optional: LP_TO=0x...

# scripts/swap-exact-in.js — exact input: transfer then swap
# SWAP_IN_TOKEN=0|1   AMOUNT_IN_WEI=...
# optional: SWAP_TO=0x...  MIN_OUT_WEI=...
